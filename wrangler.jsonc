{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rsp-ai-editor",
  "compatibility_date": "2026-06-02",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "main": ".open-next/worker.js",
  "routes": [
    { "pattern": "image-editor.co/*", "zone_name": "image-editor.co" },
    { "pattern": "www.image-editor.co/*", "zone_name": "image-editor.co" }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  }
}